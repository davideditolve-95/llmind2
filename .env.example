# .env.example — Template delle variabili d'ambiente
# Copia questo file in .env e compila i valori per il tuo ambiente

POSTGRES_USER=llmind_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=llmind_db
DATABASE_URL=postgresql://llmind_user:your_secure_password_here@db:5432/llmind_db

ICD11_API_URL=http://icd11-api
ICD11_CLIENT_ID=
ICD11_CLIENT_SECRET=

# Locale: http://host.docker.internal:11434
# Coolify: https://ollama.tuodominio.com
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=gemma4

SECRET_KEY=genera_una_chiave_casuale_sicura_di_almeno_32_caratteri
ENVIRONMENT=production

# URL pubblico del backend (Coolify: es. https://api.tuodominio.com)
NEXT_PUBLIC_API_URL=http://localhost:8000
